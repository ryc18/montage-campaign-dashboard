{
    "version": 2,
    "buildCommand": "npx vite build --config vite.config.js",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        }
    ],
    "crons": [
        {
            "path": "/api/sync/run",
            "schedule": "0 6 * * *"
        }
    ]
}